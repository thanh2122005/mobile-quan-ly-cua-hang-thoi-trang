<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tài khoản"
            android:textColor="@color/primary_purple"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_icon_circle">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="👤"
                android:textSize="40sp" />
        </FrameLayout>
        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Thành"
            android:textSize="20sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="user@gmail.com"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">
        
        <TextView
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Thông tin cá nhân"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>
            
        <TextView
            android:id="@+id/btnOrderHistory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Lịch sử đơn hàng"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Đổi mật khẩu"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>
            
        <TextView
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Giới thiệu ứng dụng"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/btnReturnAdmin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Quay lại Admin Dashboard"
            android:textColor="@color/primary_purple"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Đăng xuất"
            android:textColor="@color/error_red"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:textStyle="bold"/>
    </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation placeholder for visual only if not part of parent activity -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠\nTrang chủ"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/navCart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🛒\nGiỏ hàng"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/navOrder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📦\nĐơn hàng"
            android:textSize="12sp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👤\nTài khoản"
            android:textColor="@color/primary_purple"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
