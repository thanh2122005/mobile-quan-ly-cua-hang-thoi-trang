<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textSize="20sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sửa sản phẩm"
            android:textColor="@color/primary_purple"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Image -->
            <FrameLayout
                android:id="@+id/btnChooseImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_product_placeholder">
                <ImageView
                    android:id="@+id/ivProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="16dp"
                    android:src="@drawable/ic_shirt" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📷"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="#88FFFFFF" />
            </FrameLayout>

            <EditText
                android:id="@+id/edtProductName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:hint="Tên sản phẩm"
                android:paddingHorizontal="16dp" />

            <Spinner
                android:id="@+id/spnCategory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/edtPrice"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:hint="Giá bán"
                android:inputType="number"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/edtStock"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:hint="Số lượng"
                android:inputType="number"
                android:paddingHorizontal="16dp" />
                
            <EditText
                android:id="@+id/edtColor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:hint="Màu sắc (phân tách bằng dấu phẩy)"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/edtSizes"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:hint="Kích cỡ (phân tách bằng dấu phẩy)"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/edtDescription"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_input"
                android:gravity="top|start"
                android:hint="Mô tả sản phẩm"
                android:padding="16dp" />

            <TextView
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_orange"
                android:gravity="center"
                android:text="Cập nhật sản phẩm"
                android:textColor="@color/white"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Xóa sản phẩm này"
                android:textColor="@color/error_red"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
