<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textSize="20sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin đặt hàng"
            android:textColor="@color/primary_purple"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin người nhận"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/edtName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_input"
                android:hint="Họ và tên"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/edtPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_input"
                android:hint="Số điện thoại"
                android:inputType="phone"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/edtAddress"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_input"
                android:gravity="top|start"
                android:hint="Địa chỉ giao hàng"
                android:padding="16dp" />

            <EditText
                android:id="@+id/edtNote"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:hint="Ghi chú (tùy chọn)"
                android:paddingHorizontal="16dp" />

            <LinearLayout
                android:id="@+id/btnSelectVoucher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:id="@+id/tvSelectedVoucher"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Chọn hoặc nhập mã giảm giá"
                    android:textSize="14sp" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&gt;"
                    android:textStyle="bold"
                    android:textColor="@color/primary_purple"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tóm tắt đơn hàng"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:orientation="vertical">
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/tvTotalQuantity" android:text="Tạm tính (1 sản phẩm)" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvTotalPriceSummary" android:text="299.000đ" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                    <TextView android:text="Phí giao hàng" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvShippingFee" android:text="30.000đ" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>


                <LinearLayout android:id="@+id/llShippingDiscount" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:visibility="gone">
                    <TextView android:text="Giảm giá phí vận chuyển" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvShippingDiscount" android:text="-30.000đ" android:textColor="@color/success_green" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/llDiscountAmount" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:visibility="gone">
                    <TextView android:text="Mã giảm giá" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDiscountAmount" android:text="-0đ" android:textColor="@color/success_green" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_gray" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="Tổng cộng" android:textStyle="bold" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvOrderTotal" android:text="299.000đ" android:textStyle="bold" android:textColor="@color/accent_orange" android:textSize="18sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        android:elevation="8dp"
        android:padding="16dp">
        <TextView
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_orange"
            android:gravity="center"
            android:text="Xác nhận đặt hàng"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
